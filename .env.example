# Self-Claw 环境变量模板
# 复制为 .env 后填入实际值，不可提交到仓库

# === LLM ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === Embedding ===
EMBEDDING_MODEL=text-embedding-3-small

# === 应用 ===
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/self_claw.db
VECTOR_DB_PATH=data/vector_db

# === Agent ===
AGENT_MAX_STEPS=10
AGENT_DEFAULT_TIMEOUT_SEC=120
SUB_AGENT_MAX_PARALLEL=5

# === 会话 ===
SESSION_IDLE_TIMEOUT_MIN=30

# === Web 认证（ODR-002 待定，先用简单 token）===
API_AUTH_TOKEN=
